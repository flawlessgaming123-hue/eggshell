{
    "cli": {
        "version": ">= 14.0.0"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "autoIncrement": true,
            "android": {
                "buildType": "app-bundle"
            },
            "ios": {
                "credentialsSource": "remote"
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "serviceAccountKeyPath": "./path/to/service-account.json",
                "track": "internal"
            },
            "ios": {
                "appleId": "TODO: your Apple ID email",
                "ascAppId": "TODO: App Store Connect App ID"
            }
        }
    }
}